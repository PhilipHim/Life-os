# Google Gemini (free tier via https://aistudio.google.com/apikey)
GOOGLE_GENERATIVE_AI_API_KEY=

# Recommended — gemini-2.0-flash often has zero free quota on new keys
GEMINI_MODEL=gemini-2.5-flash

# Supabase (https://supabase.com/dashboard)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Optional — used for auth email redirect URLs in production
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Comma-separated admin emails for /admin/feedback
ADMIN_EMAILS=you@example.com

# Server-only — required to read all feedback in admin (Supabase → Settings → API → service_role)
SUPABASE_SERVICE_ROLE_KEY=
